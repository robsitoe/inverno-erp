# ─── Node.js ─────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Environment Variables ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── NestJS / Backend ────────────────────────────────────────────────────────
backend/dist/
backend/node_modules/
backend/*.log
backend/error-debug.log
backend/error.log

# ─── Angular / Frontend ──────────────────────────────────────────────────────
frontend/node_modules/
frontend/.angular/cache/
frontend/dist/

# ─── Databases (local dev) ───────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db

# ─── Uploads ─────────────────────────────────────────────────────────────────
# Keep uploads folder structure but not the files
backend/uploads/**/*
!backend/uploads/.gitkeep

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── OS Files ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── IDE ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ─── Debug scripts (temporary) ───────────────────────────────────────────────
check_*.js
fix_*.js
