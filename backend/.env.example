DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_DATABASE=inverno_erp
PORT=3000

# ─── Auth JWT (user authentication) ─────────────────────────────────────────
# IMPORTANT: Change to a strong random secret in production!
JWT_SECRET=change-this-user-jwt-secret-in-production

# ─── License JWT (license signing — SEPARATE from user auth) ─────────────────
# IMPORTANT: Change to a strong random secret in production! Keep it PRIVATE.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
LICENSE_SECRET=change-this-license-secret-in-production-keep-it-safe

# ─── Security toggles ────────────────────────────────────────────────────────
# Emergency admin/admin login when DB has no users (set to false after setup)
ALLOW_ADMIN_FALLBACK=false
# Comma-separated allowed web origins (e.g. https://erp.cliente.co.mz). Empty = reflect (LAN/dev)
ALLOWED_ORIGINS=
# Seed demo company on first run (set to false for a clean production install)
SEED_DEMO=false

# ─── e-Mola Payment Gateway ───────────────────────────────────────────────────
EMOLA_AGENT_CODE=
EMOLA_API_KEY=
EMOLA_API_SECRET=
EMOLA_SERVICE_PROVIDER_CODE=
EMOLA_BASE_URL=https://api.emola.mz/v1
EMOLA_SANDBOX=true
EMOLA_TIMEOUT=60

# ─── M-Pesa Payment Gateway ───────────────────────────────────────────────────
MPESA_API_KEY=
MPESA_PUBLIC_KEY=
MPESA_SERVICE_PROVIDER_CODE=
MPESA_BASE_URL=https://api.sandbox.vm.co.mz/ipg/v1x/
MPESA_SANDBOX=true

# ─── mKesh Payment Gateway ────────────────────────────────────────────────────
MKESH_AGENT_CODE=
MKESH_API_KEY=
MKESH_API_SECRET=
MKESH_BASE_URL=https://api.mkesh.mz/v1
